# =====================================================================
#  .env.local.example — Mẫu cho .env.local (file thật ĐÃ gitignore, KHÔNG commit)
#  Sao chép thành .env.local rồi điền giá trị nhận qua kênh an toàn.
#  KHÔNG dùng tiền tố VITE_ để Vite không bundle ra browser.
#  Chỉ dùng cho psql/migration/admin local — không cần cho người chỉ chạy dashboard.
# =====================================================================

# Kết nối Postgres trực tiếp tới Supabase VMP (pooler ap-southeast-1, port 6543)
# Role postgres — bypass RLS. Lấy tại: Supabase Dashboard -> Settings -> Database -> Connection string
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<MẬT KHẨU>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

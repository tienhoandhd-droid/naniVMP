# =====================================================================
#  .env.example — Mẫu biến môi trường (KHÔNG chứa secret, an toàn commit)
#  Sao chép thành .env cho dev cục bộ, hoặc đặt trong
#  GitHub → Settings → Secrets and variables → Actions → Variables khi deploy.
#  Chỉ biến có tiền tố VITE_ mới lộ ra client.
# =====================================================================

# ---- Supabase: NGUỒN ĐỌC/GHI DUY NHẤT (source of truth) ----
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON=<anon-key-jwt>

# ---- n8n webhook ĐỌC (fallback) ----
# Không cần thiết: dashboard đọc thẳng Supabase RPC. Để trống.
VITE_VMP_READ_URL=

# ---- n8n webhook GHI ngược Sheet ----
# CỐ Ý BỎ TRỐNG: kiến trúc hiện tại KHÓA Google Sheet (chỉ đọc), mọi chỉnh
# sửa đi qua Supabase từ dashboard. KHÔNG đặt biến này ở production —
# nếu có giá trị, app sẽ mirror ghi sang Sheet (vi phạm chính sách khóa Sheet).
# VITE_N8N_WRITE_URL=

# ---- n8n webhook cảnh báo/báo cáo AI (tuỳ chọn) ----
VITE_N8N_AI_REPORT_URL=
